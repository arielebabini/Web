# ===============================================
# CoWorkSpace Environment Variables - WINDOWS
# ===============================================

# ===============================================
# APPLICATION SETTINGS
# ===============================================
NODE_ENV=production
PORT=3000
API_BASE_URL=http://localhost

# ===============================================
# DATABASE POSTGRESQL - DOCKER WINDOWS
# ===============================================
DB_HOST=db
DB_PORT=5432
DB_NAME=coworkspace
DB_USER=coworkspace_user
DB_PASSWORD=postgress
DB_SSL=false

# Windows specific database settings
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_IDLE_TIMEOUT=30000

# ===============================================
# REDIS CACHE - DOCKER WINDOWS
# ===============================================
REDIS_URL=redis://:redis_password@redis:6379
REDIS_PASSWORD=redis_password
REDIS_HOST=redis
REDIS_PORT=6379

# ===============================================
# JWT AUTHENTICATION - PRODUCTION
# ===============================================
JWT_SECRET=your_super_secret_jwt_key_change_in_production_min_64_chars_very_secure_key_windows
JWT_EXPIRES_IN=7d

# ===============================================
# FRONTEND CONFIGURATION - WINDOWS
# ===============================================
FRONTEND_URL=http://localhost
FRONTEND_PORT=3001

# ===============================================
# CORS CONFIGURATION - WINDOWS
# ===============================================
# Permetti accesso da tutti gli indirizzi locali Windows
CORS_ORIGIN=http://localhost,http://localhost:80,http://127.0.0.1,http://127.0.0.1:80,http://host.docker.internal

# ===============================================
# WINDOWS DOCKER DESKTOP SETTINGS
# ===============================================
# Configura per Docker Desktop su Windows
DOCKER_HOST_IP=host.docker.internal

# ===============================================
# ADMIN USER - CHANGE IN PRODUCTION
# ===============================================
ADMIN_EMAIL=admin@coworkspace.test
ADMIN_PASSWORD=Admin123!

